# Contoh secrets untuk Streamlit Cloud.
# Jangan commit file .streamlit/secrets.toml yang asli.

# Ganti dengan connection string Transaction Pooler dari Supabase
SUPABASE_DB_URL = "postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"

# Opsi email cloud (isi jika mau lanjut pakai SMTP/Graph)
# SMTP_HOST = "smtp.office365.com"
# SMTP_PORT = "587"
# SMTP_USER = "your_email@company.com"
# SMTP_PASSWORD = "your_password_or_app_password"
