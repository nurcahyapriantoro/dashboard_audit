# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Build / packaging artifacts
build/
dist/
*.egg-info/
.pytest_cache/
.mypy_cache/

# IDE / OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Streamlit secrets (keep example file tracked)
.streamlit/secrets.toml

# Environment files
.env
.env.*
!.env.example

# Runtime logs
*.log

# Local runtime database/data files
project.xlsx
*.db

# Internal office files (usually sensitive, avoid pushing)
Berkas/*.xlsm
Berkas/*.xlsx
Berkas/req.txt
